# Environment
NODE_ENV=development

# Agent Configuration
AGENT_CYCLE_INTERVAL=30
AGENT_MAX_CONCURRENT_CYCLES=1

# Monitor Configuration
MONITOR_PORT=3001

# Logging
LOG_LEVEL=info

# Security
JWT_SECRET=change-this-in-production-use-strong-random-string
BCRYPT_ROUNDS=10
ADMIN_PASSWORD=admin123
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=*

# Storage
MAX_LOG_SIZE_MB=10

# Efficient AI Backend
EFFICIENT_HOST=http://localhost:8000

# API Keys
OPENAI_API_KEY=your_openai_api_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=MarkdownAgent/2.0
MEDIUM_API_KEY=your_medium_api_key

# x402 Payment Protocol
X402_ENABLED=true
X402_WALLET_ADDRESS=your_usdc_wallet_address_on_base_or_solana
X402_NETWORK=base
X402_DEFAULT_PRICE=0.005
